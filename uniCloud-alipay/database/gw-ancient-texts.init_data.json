[
  {
    "_id": "gw-at-20260308-001",
    "intro": "",
    "title": "江南春",
    "author": "杜牧",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "千里莺啼绿映红，水村山郭酒旗风。南朝四百八十寺，多少楼台烟雨中。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-002",
    "intro": "",
    "title": "乌衣巷",
    "author": "刘禹锡",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "朱雀桥边野草花，乌衣巷口夕阳斜。旧时王谢堂前燕，飞入寻常百姓家。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-003",
    "intro": "",
    "title": "浪淘沙",
    "author": "刘禹锡",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "九曲黄河万里沙，浪淘风簸自天涯。如今直上银河去，同到牵牛织女家。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-004",
    "intro": "",
    "title": "赋得古原草送别",
    "author": "白居易",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "离离原上草，一岁一枯荣。野火烧不尽，春风吹又生。远芳侵古道，晴翠接荒城。又送王孙去，萋萋满别情。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-005",
    "intro": "",
    "title": "忆江南",
    "author": "白居易",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "江南好，风景旧曾谙。日出江花红胜火，春来江水绿如蓝。能不忆江南？",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-006",
    "intro": "",
    "title": "小儿垂钓",
    "author": "胡令能",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "蓬头稚子学垂纶，侧坐莓苔草映身。路人借问遥招手，怕得鱼惊不应人。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-007",
    "intro": "",
    "title": "悯农（其一）",
    "author": "李绅",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "春种一粒粟，秋收万颗子。四海无闲田，农夫犹饿死。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-008",
    "intro": "",
    "title": "江雪",
    "author": "柳宗元",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "千山鸟飞绝，万径人踪灭。孤舟蓑笠翁，独钓寒江雪。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-009",
    "intro": "",
    "title": "剑客",
    "author": "贾岛",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "十年磨一剑，霜刃未曾试。今日把示君，谁有不平事？",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-010",
    "intro": "",
    "title": "逢雪宿芙蓉山主人",
    "author": "刘长卿",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "日暮苍山远，天寒白屋贫。柴门闻犬吠，风雪夜归人。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-011",
    "intro": "",
    "title": "送元二使安西",
    "author": "王维",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "渭城朝雨浥轻尘，客舍青青柳色新。劝君更尽一杯酒，西出阳关无故人。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-012",
    "intro": "",
    "title": "鹿柴",
    "author": "王维",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "空山不见人，但闻人语响。返景入深林，复照青苔上。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-013",
    "intro": "",
    "title": "相思",
    "author": "王维",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "红豆生南国，春来发几枝。愿君多采撷，此物最相思。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-014",
    "intro": "",
    "title": "杂诗",
    "author": "王维",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "君自故乡来，应知故乡事。来日绮窗前，寒梅著花未？",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-015",
    "intro": "",
    "title": "山中",
    "author": "王维",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "荆溪白石出，天寒红叶稀。山路元无雨，空翠湿人衣。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-016",
    "intro": "",
    "title": "鸟鸣涧",
    "author": "王维",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "人闲桂花落，夜静春山空。月出惊山鸟，时鸣春涧中。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-017",
    "intro": "",
    "title": "秋浦歌",
    "author": "李白",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "白发三千丈，缘愁似个长。不知明镜里，何处得秋霜。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-018",
    "intro": "",
    "title": "独坐敬亭山",
    "author": "李白",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "众鸟高飞尽，孤云独去闲。相看两不厌，只有敬亭山。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-019",
    "intro": "",
    "title": "夜宿山寺",
    "author": "李白",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "危楼高百尺，手可摘星辰。不敢高声语，恐惊天上人。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-020",
    "intro": "",
    "title": "古朗月行",
    "author": "李白",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "小时不识月，呼作白玉盘。又疑瑶台镜，飞在青云端。仙人垂两足，桂树何团团。白兔捣药成，问言与谁餐？",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-021",
    "intro": "",
    "title": "黄鹤楼送孟浩然之广陵",
    "author": "李白",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "故人西辞黄鹤楼，烟花三月下扬州。孤帆远影碧空尽，唯见长江天际流。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-022",
    "intro": "",
    "title": "绝句（两个黄鹂鸣翠柳）",
    "author": "杜甫",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "两个黄鹂鸣翠柳，一行白鹭上青天。窗含西岭千秋雪，门泊东吴万里船。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-023",
    "intro": "",
    "title": "八阵图",
    "author": "杜甫",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "功盖三分国，名成八阵图。江流石不转，遗恨失吞吴。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-024",
    "intro": "",
    "title": "渔歌子",
    "author": "张志和",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "西塞山前白鹭飞，桃花流水鳜鱼肥。青箬笠，绿蓑衣，斜风细雨不须归。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-025",
    "intro": "",
    "title": "塞下曲（林暗草惊风）",
    "author": "卢纶",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "林暗草惊风，将军夜引弓。平明寻白羽，没在石棱中。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-026",
    "intro": "",
    "title": "游子吟",
    "author": "孟郊",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "慈母手中线，游子身上衣。临行密密缝，意恐迟迟归。谁言寸草心，报得三春晖。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-027",
    "intro": "",
    "title": "竹枝词",
    "author": "刘禹锡",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "杨柳青青江水平，闻郎江上踏歌声。东边日出西边雨，道是无晴却有晴。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-028",
    "intro": "",
    "title": "望湖楼醉书",
    "author": "苏轼",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "黑云翻墨未遮山，白雨跳珠乱入船。卷地风来忽吹散，望湖楼下水如天。",
    "dynasty": "宋代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-029",
    "intro": "",
    "title": "四时田园杂兴（昼出耘田夜绩麻）",
    "author": "范成大",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "昼出耘田夜绩麻，村庄儿女各当家。童孙未解供耕织，也傍桑阴学种瓜。",
    "dynasty": "宋代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-030",
    "intro": "",
    "title": "四时田园杂兴（梅子金黄杏子肥）",
    "author": "范成大",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "梅子金黄杏子肥，麦花雪白菜花稀。日长篱落无人过，惟有蜻蜓蛱蝶飞。",
    "dynasty": "宋代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-031",
    "intro": "",
    "title": "晓出净慈寺送林子方",
    "author": "杨万里",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "毕竟西湖六月中，风光不与四时同。接天莲叶无穷碧，映日荷花别样红。",
    "dynasty": "宋代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-032",
    "intro": "",
    "title": "舟过安仁",
    "author": "杨万里",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "一叶渔船两小童，收篙停棹坐船中。怪生无雨都张伞，不是遮头是使风。",
    "dynasty": "宋代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-033",
    "intro": "",
    "title": "游园不值",
    "author": "叶绍翁",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "应怜屐齿印苍苔，小扣柴扉久不开。春色满园关不住，一枝红杏出墙来。",
    "dynasty": "宋代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-034",
    "intro": "",
    "title": "乡村四月",
    "author": "翁卷",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "绿遍山原白满川，子规声里雨如烟。乡村四月闲人少，才了蚕桑又插田。",
    "dynasty": "宋代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-035",
    "intro": "",
    "title": "石灰吟",
    "author": "于谦",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "千锤万凿出深山，烈火焚烧若等闲。粉骨碎身全不怕，要留清白在人间。",
    "dynasty": "明代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-036",
    "intro": "",
    "title": "竹石",
    "author": "郑燮",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "咬定青山不放松，立根原在破岩中。千磨万击还坚劲，任尔东西南北风。",
    "dynasty": "清代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-037",
    "intro": "",
    "title": "长歌行",
    "author": "汉乐府",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "青青园中葵，朝露待日晞。阳春布德泽，万物生光辉。常恐秋节至，焜黄华叶衰。百川东到海，何时复西归？少壮不努力，老大徒伤悲。",
    "dynasty": "汉代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-038",
    "intro": "",
    "title": "七步诗",
    "author": "曹植",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "煮豆燃豆萁，豆在釜中泣。本是同根生，相煎何太急？",
    "dynasty": "三国",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-039",
    "intro": "",
    "title": "渡汉江",
    "author": "李频",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "岭外音书断，经冬复历春。近乡情更怯，不敢问来人。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-040",
    "intro": "",
    "title": "易水送别",
    "author": "骆宾王",
    "is_hot": false,
    "source": "幼儿园100天100首古诗",
    "content": "此地别燕丹，壮士发冲冠。昔时人已没，今日水犹寒。",
    "dynasty": "唐代",
    "created_at": {
      "$date": "2026-03-08T00:00:00.000Z"
    }
  },
  {
    "_id": "gw-at-20260308-041",
    "intro": "",
    "title": "中秋月",
