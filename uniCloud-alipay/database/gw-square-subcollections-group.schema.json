{
  "bsonType": "object",
  "required": ["subcollection_id", "name"],
  "permission": {
    "read": true,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "ID",
      "label": "ID"
    },
    "subcollection_id": {
      "bsonType": "string",
      "description": "子合集ID，参考gw-square-subcollections._id",
      "label": "子合集ID",
      "trim": "both",
      "foreignKey": "gw-square-subcollections._id"
    },
    "name": {
      "bsonType": "string",
      "description": "分组名称",
      "label": "分组名称",
      "trim": "both"
    },
    "sort": {
      "bsonType": "int",
      "description": "排序",
      "label": "排序",
      "defaultValue": 0
    },
    "enabled": {
      "bsonType": "bool",
      "description": "是否启用",
      "label": "是否启用",
      "defaultValue": true
    },
    "created_at": {
      "bsonType": "timestamp",
      "description": "创建时间",
      "label": "创建时间",
      "defaultValue": {
        "$env": "now"
      }
    }
  }
}
